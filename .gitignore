# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg

# Virtualenv
venv/
.venv/
env/

# Build artifacts
build/
dist/
*.spec

# Runtime
logs/
*.log

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Local test data — committing arbitrary PDFs / DOCX blobs would bloat
# the repo. tests/data/ holds the small public synthetic samples (see
# the negation rule below).
*.pdf
*.docx
!tests/data/*.pdf
!tests/data/*.docx

# User's private testing documents (not for the public repo).
test-docs/

# Claude Code workspace state
.claude/
.claude-plans/
